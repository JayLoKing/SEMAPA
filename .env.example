# ============================================================================
# SEMAPA - Variables de entorno
# Copia este archivo a .env y ajusta los valores
# NUNCA subas .env al repositorio
# ============================================================================

# ===== Cassandra =====
CASSANDRA_HOSTS=cassandra-1,cassandra-2
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=semapa
CASSANDRA_USER=cassandra
CASSANDRA_PASSWORD=cassandra
CASSANDRA_DC=datacenter1
CASSANDRA_REPLICATION_FACTOR=2

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== RabbitMQ =====
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=semapa
RABBITMQ_PASSWORD=semapa
RABBITMQ_MGMT_PORT=15672
RABBITMQ_VHOST=/

# ===== JWT =====
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=720

# ===== SMTP (Mailhog en desarrollo) =====
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@semapa.bo
SMTP_USE_TLS=false

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=http://localhost,http://localhost:5173

# ===== Frontend Web =====
VITE_API_URL=http://localhost/api/v1
VITE_APP_NAME=SEMAPA

# ===== App Móvil =====
EXPO_PUBLIC_API_URL=http://10.0.2.2/api/v1

# ===== Cotización USD =====
USD_API_URL=https://api.exchangerate.host/latest?base=USD&symbols=BOB
USD_CACHE_TTL=900
USD_FALLBACK_RATE=6.96

# ===== Simulador LoRaWAN =====
SIMULATOR_OUTPUT_DIR=/lora-data
SIMULATOR_BURST_SIZE=120
SIMULATOR_ERROR_RATE=0.005
SIMULATOR_DUPLICATE_RATE=0.0007

# ===== Ingestor =====
INGESTOR_WATCH_DIR=/lora-data
INGESTOR_BATCH_SIZE=30
INGESTOR_CONCURRENCY=100
INGESTOR_DEDUP_TTL=86400

# ===== Seeder =====
SEEDER_PERSONAS_NATURALES=80000
SEEDER_PERSONAS_JURIDICAS=5000
SEEDER_INFRAESTRUCTURAS=100000
SEEDER_MEDIDORES=120000
SEEDER_FECHA_INICIO_LECTURAS=2025-04-01
SEEDER_CONCURRENCY=100
SEEDER_BATCH_SIZE=30

# ===== Mock APIs (SMS / WhatsApp) =====
SMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ===== Observabilidad =====
LOG_FORMAT=json
LOG_LEVEL=INFO
